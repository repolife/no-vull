# LLM Provider (claude | ollama | lmstudio | gemini | openai)
NO_VULL_PROVIDER=claude
NO_VULL_MODEL=

# Optional shell-command provider.
# Prompt is written to stdin; stdout must contain the JSON report.
# Example: NO_VULL_PROVIDER=command
# Example: NO_VULL_COMMAND=claude -p
NO_VULL_COMMAND=

# API keys — only needed for the chosen provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# X/Twitter Bearer Token — enables real-time security chatter monitoring
X_BEARER_TOKEN=
